# ──────────────────────────────────────────────────────────────────────────────
# Atlassian Rovo MCP Demo – Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Leave DEMO_MODE=true to run the demo without real Atlassian credentials.

# Demo Mode (set to false to use real Atlassian APIs)
DEMO_MODE=true

# ──────────────────────────────────────────────────────
# Atlassian Configuration (required when DEMO_MODE=false)
# ──────────────────────────────────────────────────────
# Your Atlassian Cloud base URL (e.g. https://yourorg.atlassian.net)
ATLASSIAN_BASE_URL=https://yourorg.atlassian.net

# Atlassian API token – generate at https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your_api_token_here

# Your Atlassian account email
ATLASSIAN_USER_EMAIL=you@yourorg.com

# ──────────────────────────────────────────────────────
# Confluence Settings
# ──────────────────────────────────────────────────────
# Space key containing eShop documentation
CONFLUENCE_SPACE_KEY=ENG

# Optional: specific page ID to read (if not set, agent searches the space)
# CONFLUENCE_PAGE_ID=123456

# ──────────────────────────────────────────────────────
# Jira Settings
# ──────────────────────────────────────────────────────
# Jira project key for migration tasks
JIRA_PROJECT_KEY=ESHOP

# Epic to link migration stories to (and post summary comment on)
JIRA_EPIC_KEY=ESHOP-1

# ──────────────────────────────────────────────────────
# LLM API Keys (optional – enhances analysis quality)
# ──────────────────────────────────────────────────────
# Provide ONE of the following for LLM-powered analysis.
# If neither is set, the agent uses rule-based analysis (always works).

# Anthropic Claude (recommended)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o (alternative)
# OPENAI_API_KEY=sk-...
