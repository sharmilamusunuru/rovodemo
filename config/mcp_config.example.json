{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "MCP server configuration for Atlassian Rovo – copy to mcp_config.json and fill in your credentials",
  "mcpServers": {
    "atlassian-confluence": {
      "command": "npx",
      "args": ["-y", "@atlassian/mcp-confluence"],
      "env": {
        "ATLASSIAN_BASE_URL": "${ATLASSIAN_BASE_URL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}",
        "ATLASSIAN_USER_EMAIL": "${ATLASSIAN_USER_EMAIL}"
      },
      "tools": [
        "confluence_get_page",
        "confluence_search",
        "confluence_create_page",
        "confluence_update_page"
      ]
    },
    "atlassian-jira": {
      "command": "npx",
      "args": ["-y", "@atlassian/mcp-jira"],
      "env": {
        "ATLASSIAN_BASE_URL": "${ATLASSIAN_BASE_URL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}",
        "ATLASSIAN_USER_EMAIL": "${ATLASSIAN_USER_EMAIL}"
      },
      "tools": [
        "jira_search_issues",
        "jira_get_issue",
        "jira_create_issue",
        "jira_update_issue",
        "jira_add_comment"
      ]
    }
  }
}
